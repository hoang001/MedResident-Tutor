APP_NAME=Medical Resident Learning Assistant
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
POSTGRES_DB=medical_learning
POSTGRES_USER=medical_user
POSTGRES_PASSWORD=local_development_password
DATABASE_URL=postgresql+asyncpg://medical_user:local_development_password@db:5432/medical_learning
JWT_SECRET_KEY=replace-with-a-long-random-secret-for-any-non-local-use
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000
FILE_STORAGE_PATH=/app/data/uploads
MAX_UPLOAD_SIZE_MB=10
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_LEARNER_EMAIL=learner@example.local
SEED_LEARNER_PASSWORD=ChangeMe123!

